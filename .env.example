# Required for chat bot
GEMMA_API_KEY=

# Required for contact form (Cloudflare Turnstile)
TURNSTILE_SECRET_KEY=

# Required for contact form emails (Resend)
RESEND_API_KEY=

# Optional: set to 'true' to block indexing (dev site)
# NUXT_PUBLIC_NO_INDEX=true

# Optional: build identifier
# NUXT_PUBLIC_BUILD_ID=dev

# Optional: custom Lighthouse audit URL
# LIGHTHOUSE_URL=https://nemesisnet.co.za
